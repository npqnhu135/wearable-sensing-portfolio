    "# Cell 5: per-phase metrics — rise time, decay time\n",
    "def fit_exponential_rise(t, T, T_baseline):\n",
    "    \"\"\"T(t) = T_baseline + A * (1 - exp(-t/tau))\"\"\"\n",
    "    def model(t, A, tau):\n",
    "        return T_baseline + A * (1 - np.exp(-(t - t[0]) / tau))\n",
    "    p0 = [T.max() - T_baseline, 1.0]\n",
    "    popt, pcov = curve_fit(model, t, T, p0=p0)\n",
    "    return popt[0], popt[1]  # A, tau (in min)"
   ]
  },
