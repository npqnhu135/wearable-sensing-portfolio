    "# Cell 6: fit Phase 1 rise as example\n",
    "baseline = df[df.time_min < 0.3].temperature_c.mean()\n",
    "mask = (df.time_min >= phases['Phase 1']['start']) & (df.time_min <= phases['Phase 1']['end'])\n",
    "t_p1, T_p1 = df.loc[mask, 'time_min'].values, df.loc[mask, 'temperature_c'].values\n",
    "# only the rise portion (until plateau)\n",
    "rise_end = t_p1[np.argmax(T_p1)]\n",
    "mask_rise = t_p1 <= rise_end\n",
    "A1, tau1 = fit_exponential_rise(t_p1[mask_rise], T_p1[mask_rise], baseline)\n",
    "print(f\"Phase 1 rise: A={A1:.2f}°C, tau={tau1*60:.1f}s\")"
   ]
